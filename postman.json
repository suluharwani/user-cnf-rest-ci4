    {
      "name": "7. CDN File Management",
      "item": [
        {
          "name": "Upload Single File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.file && jsonData.file.id) {",
                  "    pm.environment.set(\"cdn_file_id\", jsonData.file.id);",
                  "    console.log('File ID:', jsonData.file.id);",
                  "    console.log('URL:', jsonData.file.url);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "Pilih file (max 10 MB, semua ekstensi)",
                  "value": null
                },
                {
                  "key": "folder",
                  "value": "/images",
                  "type": "text",
                  "description": "Folder tujuan (default: /)"
                },
                {
                  "key": "is_public",
                  "value": "1",
                  "type": "text",
                  "description": "1 = Public, 0 = Private"
