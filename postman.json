            "body": {
              "mode": "raw",
              "raw": "{\n    \"role_id\": {{role_inventory_manager_id}},\n    \"permissions\": [\n        {\n            \"application_id\": {{app_inventory_id}},\n            \"module_id\": {{module_products_id}},\n            \"can_create\": 1,\n            \"can_read\": 1,\n            \"can_update\": 1,\n            \"can_delete\": 1\n        },\n        {\n            \"application_id\": {{app_inventory_id}},\n            \"module_id\": {{module_stock_id}},\n            \"can_create\": 1,\n            \"can_read\": 1,\n            \"can_update\": 1,\n            \"can_delete\": 1\n        }\n    ]\n}"
            },
            "url": {
